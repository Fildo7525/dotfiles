{
	"layer": "top",
	"position": "top",
	"autohide": false,
	"autohide-blocked": false,
	"exclusive": true,
	"passthrough": false,
	"gtk-layer-shell": true,
	"spacing": 1,

	// Choose the order of the modules
	"modules-left": [
		"hyprland/workspaces",
		"group/hardware",
		"hyprland/submap",
	],
	"modules-center": [
		"custom/spotify",
		"clock",
		"custom/notification",
	],
	"modules-right": [
		"network",
		"bluetooth",
		"group/pulseaudio",
		"backlight",
		"group/power",
		"custom/language",
		"custom/clipboard",
		"tray",
	],

	/* ===== Modules Left ===== */
	"group/hardware": {
		"modules": [
			"cpu",
			"memory",
			"custom/disk",
		],
		"separator": "|",
		"orientation": "horizontal",
	},
	"cpu": {
		"format": "{usage}% ´Æ╝",
		"tooltip": true,
		"on-click": "SHELL=/usr/bin/bash foot -a btop btop",
	},
	"memory": {
		"format": "{}% ´âë",
		"tooltip": true,
		"tooltip-format": "Percentage: {percentage}%\nUsed: {used} GiB\nAvailable: {avail} GiB\nTotal: {total} GiB\n\nSwap Percentage: {swapPercentage}%\nSwap Used: {swapUsed} GiB\nSwap Available: {swapAvail} GiB\nSwap Total: {swapTotal} GiB",
		"on-click": "SHELL=/usr/bin/bash foot -a btop btop",
	},
	"custom/disk": {
		"exec": "~/.config/waybar/scripts/disk",
		"tooltip": true,
		"return-type": "json",
		"interval": 3600,
		"on-click": "SHELL=/usr/bin/bash foot -a btop btop",
	},

	/* ===== Modules Center ===== */
	"clock": {
		"timezone": "Europe/Copenhagen",
		"tooltip-format": "<big>{:%Y}</big>\n<tt><small>{calendar}</small></tt>",
		"format": "<big>{:%H:%M}</big>",
		"format-alt": "<big>{:%H:%M	%Y-%m-%d}</big>",
		"on-click-middle": "gnome-calendar",
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"calendar": {
			"mode": "month",
			"mode-mon-col": 3,
			"weeks-pos" : "left",
			"on-scroll" : 1,
			"format": {
				"months": "<span color='#cdd6f4'><b>{}</b></span>",
				"days": "<span color='#b4befe'><b>{}</b></span>",
				"weeks": "<span color='#a6e3a1'><b>W{}</b></span>",
				"weekdays": "<span color='#fab387'><b>{}</b></span>",
				"today": "<span color='#f38ba8'><b><u>{}</u></b></span>",
			},
		},
	},
	"custom/notification": {
		"tooltip": true,
		"format": "<span size='16pt'>{icon}</span>",
		"format-icons": {
			"notification": "¾▒à½",
			"none": "¾░é£",
			"dnd-notification": "¾░éá",
			"dnd-none": "¾░¬ô",
			"inhibited-notification": "¾░éø",
			"inhibited-none": "¾░¬æ",
			"dnd-inhibited-notification": "¾░éø",
			"dnd-inhibited-none": "¾░¬æ",
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true,
	},
	"custom/spotify": {
		"format": "{}",
		"escape": true,
		"return-type": "json",
		"max-length": 20,
		"on-click": "playerctl -p spotify play-pause",
		"on-click-right": "killall spotify",
		"smooth-scrolling-threshold": 10,
		"on-scroll-up" : "playerctl -p spotify next",
		"on-scroll-down" : "playerctl -p spotify previous",
		"exec": "~/.config/waybar/scripts/mediaplayer.py --player spotify 2> /dev/null",
	},

	/* ===== Modules Right ===== */
	"network": {
		// "interface": "wlp2*", // (Optional) To force the use of this interface
		"format": "´üó {bandwidthUpBytes} ´üú {bandwidthDownBytes} {icon}",
		"format-disconnected": "¾░îÖ ¾░û¬",
		"format-disabled": "´åô ¾░û¬",
		"format-alt": "¯¥ö {ifname}: {ipaddr}/{cidr}",
		"format-icons": {
			"wifi": "´ç½",
			"ethernet": "¾░êü",
			"linked": "´Şû",
			"disconnected": "¾░û¬",
			"disabled": "¾░û¬",
		},
		"interval": 2,
		"tooltip": true,
		"tooltip-format": "{ifname}\n{essid} @ {frequency} MHz \nIP: {ipaddr}/{cidr}\nStrength: {signalStrength}% {signaldBm}dBm\nGateway: {gwaddr}",
		"on-click-middle": "SHELL=/usr/bin/bash; nmcli device wifi rescan; foot -a nmtui nmtui",
		"on-click-right": "~/.config/waybar/scripts/wifi toggle",
	},
	"bluetooth": {
		"format": "{icon}",
		"format-connected": "{device_alias} ´èö",
		"format-connected-battery": "{device_alias} ´èö {device_battery_percentage}%",
		"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click-right": "~/.config/waybar/scripts/bluetooth toggle",
		"on-click-middle": "blueman-manager",
		"format-icons": {
			"disabled": "´åô ¾░é▓",
			"off": "¾░é▓",
			"on": "´èö",
			"connected": "´èö",
			"discoverable": "¾░é▒",
			"discovering": "¾░é░",
			"pairable": "´èô",
		}
	},
	"group/pulseaudio": {
		"modules": [
			"pulseaudio#output",
			"pulseaudio#input",
		],
		"separator": "|",
		"orientation": "horizontal",
	},
	"pulseaudio#input": {
		"format-source": "{volume} ¯░£",
		"format-source-muted": "¾░ı¡",
		"format-source-bluetooth": "{volume} ¯░£ ´èö",
		"format-source-bluetooth-muted": "¾░ı¡ ´èö",
		"format": "{format_source}",
		"on-click-middle": "pavucontrol",
		"on-click-right": "~/.config/waybar/scripts/volume source toggle",
		"on-scroll-up": "~/.config/waybar/scripts/volume source up",
		"on-scroll-down": "~/.config/waybar/scripts/volume source down",
		"tooltip": false,
		"interval": 20,
	},
	"pulseaudio#output": {
		"format": "{volume} {icon}",
		"format-bluetooth": "{volume} {icon} ´èö",
		"format-bluetooth-muted": "¾░Øş ´èö",
		"max-volume": 153,
		"format-icons": {
			"default": [
				"´ÇĞ",
				"´Çğ",
				"´Ç¿",
				"´Ç¿",
			]
		},
		"on-click-middle": "pavucontrol",
		"on-click-right": "~/.config/waybar/scripts/volume sink toggle",
		"on-scroll-up": "~/.config/waybar/scripts/volume sink up",
		"on-scroll-down": "~/.config/waybar/scripts/volume sink down",
		"tooltip": false
	},
	"backlight": {
		"device": "acpi_video1",
		"format": "{percent}% {icon}",
		"format-icons": ["¯Äı", "¯Åô", "¯Åæ", "¯ÅÅ", "¯ÅÄ", "¯Åı", "¯Åè", "¯Åê", "¯Äø"],
	},
	"group/power": {
		"modules": [
			"custom/powerprofile",
			"custom/conservation",
			"battery",
			"custom/power",
		],
		"separator": "|",
		"orientation": "horizontal",
	},
	"custom/powerprofile": {
		"format": "{icon}",
		"format-icons": {
			"performance": "¾░èù",
			"balanced": "´ëÄ",
			"power-saver": "´ïï",
		},
		"exec": "~/.config/waybar/scripts/powerprofile",
		"on-click": "~/.config/waybar/scripts/powerprofile menu",
		"on-scroll-up": "~/.config/waybar/scripts/powerprofile previous",
		"on-scroll-down": "~/.config/waybar/scripts/powerprofile next",
		"return-type": "json",
		"interval": 1,
	},
	"custom/power": {
		"format" : "ÔÅ╗",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "~/dotfiles/waybar/scripts/power_menu.xml",
		"menu-actions": {
			"shutdown": "shutdown",
			"reboot": "reboot",
			"suspend": "systemctl suspend",
			"hibernate": "systemctl hibernate",
		},
	},
	"custom/conservation": {
		"format": "{icon}",
		"format-icons": {
			"conserv_on": "¾░éä",
			"conserv_off": "´çĞ",
		},
		"exec": "~/.config/waybar/scripts/conservation",
		"on-click": "~/.config/waybar/scripts/conservation toggle",
		"return-type": "json",
		"interval": 1,
	},
	"battery": {
		"states": {
			"good": 55,
			"warning": 30,
			"critical": 15,
		},
		"format": "{capacity}% {icon}",
		"format-charging": "{capacity}% ¾░éä",
		"format-plugged": "{capacity}% ´çĞ",
		"tooltip-format": "{timeTo}",
		"format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
		"interval": 30,
	},
	"custom/language": {
		"format": "´ä£ {}",
		"exec": "~/.config/waybar/scripts/language",
		"tooltip": false,
		"interval": 1,
	},
	"custom/clipboard": {
		"format": "{}",
		"return-type": "json",
		"exec": "~/.config/waybar/scripts/clipboard",
		"exec-if": "[ -x \"$(command -v cliphist)\" ] && [ $(cliphist list | wc -l) -gt 0 ]",
		"interval": 3600,
		"on-click": "~/.config/waybar/scripts/clipboard choose",
		"on-click-right": "cliphist wipe",
	},
	"tray": {
		"icon-size": 21,
		"spacing": 10,
		"icons": {
			"blueman": "bluetooth",
			"TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
		}
	}
}
